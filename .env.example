# === ALADIN B2B — Environment Variables ===
# Copy this to .env and fill in your values

# === DATABASE (Turso / libSQL for Vercel) ===
# Create a free Turso DB: https://turso.tech
# Then run: npx prisma db push
DATABASE_URL="libsql://aladin-demo-YOUR-ORG.turso.io"
DIRECT_URL="libsql://aladin-demo-YOUR-ORG.turso.io"

# === LOCAL DEVELOPMENT (SQLite file) ===
# Uncomment for local dev, comment out Turso URLs above
# DATABASE_URL="file:./db/custom.db"
# DIRECT_URL=""

# === AUTH ===
JWT_SECRET="change-this-to-a-random-string"
NODE_ENV="production"

# === TURSO AUTH ===
# Get from: turso db tokens create aladin-demo
TURSO_AUTH_TOKEN="your-turso-auth-token"

# === OPTIONAL ===
# SETUP_SECRET="your-setup-secret"  # Protects /api/setup endpoint