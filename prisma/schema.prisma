// ============================================================
// ALADIN PLATFORM — Complete Database Schema
// B2B AI-Powered Commerce Platform for Vietnam
// ============================================================
// Architecture: Modular Monolith (Next.js App Router)
// Database: Neon PostgreSQL (serverless)
// Local dev:  DATABASE_URL=postgresql://... (Neon)
// Vercel:      DATABASE_URL=postgresql://... (Neon, same)
// Conventions: UTC timestamps, append-only ledger, soft deletes
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS (PostgreSQL: defined as String with app-layer validation
// for flexibility — can migrate to native enums later)
// ============================================================

// User Roles
// ADMIN, SHOP_OWNER, SALES_REP, DRIVER, BROKER, DISTRIBUTOR

// User Status
// ACTIVE, SUSPENDED, PENDING_VERIFICATION

// Order Status
// PENDING, CONFIRMED, PROCESSING, PACKED, OUT_FOR_DELIVERY, DELIVERED, CANCELLED, REFUNDED

// Payment Method
// CREDIT, DIGITAL, COD

// Payment Status
// PENDING, PAID, FAILED, REFUNDED, PARTIALLY_REFUNDED

// Transaction Type
// CREDIT_USED, REPAYMENT, CREDIT_LIMIT_INCREASE, CREDIT_LIMIT_DECREASE, ORDER_PAYMENT, REFUND
// DISTRIBUTOR_PAYOUT, DRIVER_PAYOUT, PLATFORM_FEE

// Shipment Status
// PENDING, PICKED_UP, IN_TRANSIT, DELIVERED, FAILED

// Settlement Status
// PENDING, PROCESSING, PAID, FAILED

// Inventory Movement Type
// RECEIPT, ADJUSTMENT, ORDER_FULFILLMENT, RETURN, DAMAGE

// Group Deal Status
// ACTIVE, COMPLETED, CANCELLED, EXPIRED

// ============================================================
// CORE: USERS & AUTHENTICATION
// ============================================================

model User {
  id            String   @id @default(cuid())
  phone         String   @unique                            // Primary login (Vietnamese phone)
  email         String?  @unique                            // Optional email
  passwordHash  String?                                     // Null = Zalo-only login
  name          String
  nameEn        String?                                     // English name variant
  avatarUrl     String?
  role          String   @default("SHOP_OWNER")             // ADMIN, SHOP_OWNER, SALES_REP, DRIVER, BROKER, DISTRIBUTOR
  status        String   @default("ACTIVE")                 // ACTIVE, SUSPENDED, PENDING_VERIFICATION
  zaloId        String?  @unique                            // Zalo OA user ID for 1-tap login
  lastLoginAt   DateTime?
  mustChangePwd Boolean  @default(false)
  
  // Relations
  shop          Shop?
  broker        Broker?
  distributor   DistributorUser?
  shipments     Shipment[]  @relation("DriverAssignments")
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
  notificationPrefs    NotificationPreference?

  // Metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?                                     // Soft delete

  @@index([phone])
  @@index([role])
  @@index([status])
}

// ============================================================
// CORE: SHOPS (Mom-and-pop tạp hóa)
// ============================================================

model Shop {
  id            String   @id @default(cuid())
  userId        String   @unique
  name          String                                       // Shop display name
  nameEn        String?                                     // English variant
  wardId        String?                                     // Geographic ward for group buying
  district      String?                                     // E.g., Thu Dau Mot
  province      String   @default("Binh Duong")
  address       String?
  lat           Float?                                       // GPS for delivery routing
  lng           Float?
  shopType      String   @default("TAPHOA")                 // TAPHOA, CONVENIENCE, FACTORY
  loyaltyTier   String   @default("BRONZE")                 // BRONZE, SILVER, GOLD, PLATINUM

  // Credit System (7-day micro-credit, 2-5M VND starting limits)
  creditLimit   Int      @default(2000000)                  // In VND (default 2M, range 2-5M)
  creditBalance Int      @default(0)                        // Currently used credit (VND)
  creditStatus  String   @default("ACTIVE")                 // ACTIVE, LOCKED, OVERDUE
  creditTermsDays Int    @default(7)                        // 7-day repayment terms
  
  // Stats
  totalOrders   Int      @default(0)
  totalGmv      Int      @default(0)                        // Lifetime GMV in VND
  avgOrderValue Int      @default(0)
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ward          Ward?    @relation(fields: [wardId], references: [id])
  orders        Order[]
  transactions  Transaction[]
  groupParticipations GroupDealParticipant[]

  // Metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([userId])
  @@index([wardId])
  @@index([district])
  @@index([creditStatus])
}

// ============================================================
// CORE: WARD / ZONE (Geographic clustering for group buy)
// ============================================================

model Ward {
  id          String @id @default(cuid())
  name        String                                     // E.g., "Phu My Ward"
  nameEn      String?                                   // English variant
  district    String                                     // E.g., "Thu Dau Mot"
  province    String @default("Binh Duong")
  shopCount   Int    @default(0)                         // Denormalized for performance
  
  // Relations
  shops       Shop[]
  groupDeals  GroupDeal[]
  brokers     Broker[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([district])
  @@index([province])
}

// ============================================================
// PRODUCT CATALOG
// ============================================================

model Category {
  id          String     @id @default(cuid())
  name        String                               // Vietnamese name
  nameEn      String?                             // English name
  slug        String     @unique
  icon        String?                             // Emoji or icon name
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  
  // Relations
  products    Product[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([slug])
  @@index([sortOrder])
}

model Product {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String                              // Vietnamese name
  nameEn        String?                            // English name
  description   String?                            // Vietnamese description
  descriptionEn String?                            // English description
  categoryId    String
  brand         String?                            // E.g., "Hao Hao", "Unilever"
  unit          String   @default("cai")           // Unit type: bao, chai, thung, goi
  unitEn        String?                            // English unit
  basePrice     Int                                 // Base price in VND (smallest unit)
  groupBuyPrice Int?                               // Discounted price for group deals (VND)
  stockQuantity Int      @default(0)               // Available inventory
  minOrderQty   Int      @default(1)
  maxOrderQty   Int?                               // Null = unlimited
  weightKg      Float?                              // For delivery cost calculation
  imageUrl      String?
  isActive      Boolean  @default(true)
  isPrivateLabel Boolean @default(false)            // Aladin Select house brand
  barcode       String?  @unique                    // For OCR scanning
  
  // Manufacturer / Supplier
  manufacturerId String?
  distributorId   String?
  
  // Relations
  category        Category      @relation(fields: [categoryId], references: [id])
  manufacturer    Manufacturer?  @relation(fields: [manufacturerId], references: [id])
  distributor     Distributor?   @relation(fields: [distributorId], references: [id])
  orderItems      OrderItem[]
  promotionItems  PromotionItem[]
  groupDeals      GroupDeal[]
  inventory       DistributorInventory[]
  inventoryMovements InventoryMovement[]
  priceTierItems  PriceTierItem[] @relation("PriceTierProduct")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([categoryId])
  @@index([sku])
  @@index([manufacturerId])
  @@index([isActive])
  @@index([name])
}

// ============================================================
// SUPPLY CHAIN: MANUFACTURERS & DISTRIBUTORS
// ============================================================

model Manufacturer {
  id            String   @id @default(cuid())
  name          String
  nameEn        String?
  contactPerson String?
  contactPhone  String?
  email         String?
  address       String?
  province      String?
  commissionRate Float   @default(0.15)           // 15% standard margin
  
  // Relations
  products      Product[]
  promotions    Promotion[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
}

model Distributor {
  id            String   @id @default(cuid())
  name          String
  nameEn        String?
  contactPerson String?
  contactPhone  String?
  email         String?
  address       String?
  lat           Float?
  lng           Float?                             // For smart sourcing distance calc
  isActive      Boolean  @default(true)

  // Financial: Distributor Settlement
  bankName      String?                                     // Bank account info for payouts
  bankAccount   String?
  bankHolder    String?
  taxId         String?                                     // MST for invoicing
  commissionRate Float   @default(0.03)                    // Platform fee % (default 3%)
  deliveryFeeShare Float @default(1.0)                     // 1.0 = distributor bears 100% of delivery fee

  // Stats
  totalOrdersFulfilled  Int    @default(0)
  totalRevenue          Int    @default(0)                 // Total product revenue earned (VND)
  totalPayouts          Int    @default(0)                 // Total paid out (VND)
  pendingPayoutAmount   Int    @default(0)                 // Awaiting next settlement
  
  // Relations
  user          DistributorUser?
  products      Product[]
  inventory     DistributorInventory[]
  inventoryMovements InventoryMovement[]
  settlements   Settlement[]
  orders        Order[]
  posShifts     PosShift[]    @relation("DistributorPosShifts")
  posSaleItems  PosSaleItem[] @relation("DistributorPosSales")
  customers     DistributorCustomer[]
  loyaltyTransactions LoyaltyTransaction[]
  priceTiers    PriceTier[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
}

// Distributor-User link (1:1, like Shop/Broker)
model DistributorUser {
  id              String     @id @default(cuid())
  userId          String     @unique
  distributorId   String     @unique

  // Relations
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  distributor     Distributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// ORDERS (The core transaction)
// ============================================================

model Order {
  id                String    @id @default(cuid())
  orderNumber       String    @unique                // Human-readable: "ALD-20260418-001"
  shopId            String
  shopSnapshot      String                            // JSON: shop details at order time (for audit)
  
  // Status
  status            String    @default("PENDING")     // PENDING → CONFIRMED → PROCESSING → PACKED → OUT_FOR_DELIVERY → DELIVERED
  
  // Payment
  paymentMethod     String    @default("COD")         // CREDIT, DIGITAL, COD
  paymentStatus     String    @default("PENDING")     // PENDING, PAID, FAILED, REFUNDED
  subtotalAmount    Int                                // Sum of items (VND)
  discountAmount    Int      @default(0)              // Promo discounts
  deliveryFee       Int      @default(0)
  totalAmount       Int                                // Final amount
  paidAmount        Int      @default(0)              // Amount actually paid
  
  // Credit
  creditUsed        Int      @default(0)              // If paid via 7-day credit
  
  // Group Buy
  groupDealId       String?                            // If this order is part of a group deal
  
  // Fulfillment
  distributorId     String?                            // Which distributor sourced from
  assignedDriverId  String?                            // Internal driver assignment
  thirdPartyOrderId String?                            // Ahamove/Grab tracking ID
  
  // Notes
  customerNotes     String?
  adminNotes        String?
  
  // Idempotency
  idempotencyKey    String?   @unique                  // Prevent double-order on 3G

  // Relations
  shop              Shop      @relation(fields: [shopId], references: [id])
  distributor       Distributor? @relation(fields: [distributorId], references: [id])
  items             OrderItem[]
  transactions      Transaction[]
  shipment          Shipment?
  groupDeal         GroupDeal? @relation(fields: [groupDealId], references: [id])
  payments          Payment[]

  // Fulfillment tracking
  fulfilledByDistributorAt DateTime?                       // When distributor marked order ready

  // Metadata
  confirmedAt       DateTime?
  packedAt          DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([shopId])
  @@index([status])
  @@index([paymentMethod])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([distributorId])
  @@index([groupDealId])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  productName     String                             // Snapshot: name at time of order
  productSku      String                             // Snapshot: SKU at time of order
  unitPrice       Int                                 // Price at time of order (VND)
  quantity        Int
  totalPrice      Int                                 // unitPrice * quantity
  
  // Promotion applied to this item
  promotionId     String?
  freeQty         Int      @default(0)               // "Buy 10 Get 1" → freeQty = 1
  
  // Relations
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])
  promotion       Promotion? @relation(fields: [promotionId], references: [id])

  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ============================================================
// FINANCIAL: APPEND-ONLY LEDGER (7-Day Credit System)
// CRITICAL: NEVER mutate credit_balance directly on Shop.
// Always create Transaction records. Balance = SUM(credit transactions).
// ============================================================

model Transaction {
  id              String   @id @default(cuid())
  shopId          String
  orderId         String?                             // Related order (if credit used)
  
  // Transaction details
  type            String                              // CREDIT_USED, REPAYMENT, CREDIT_LIMIT_INCREASE, CREDIT_LIMIT_DECREASE, ORDER_PAYMENT, REFUND
  amount          Int                                 // Amount in VND (positive = debit, negative = credit to shop)
  runningBalance  Int                                 // Credit balance AFTER this transaction
  
  // Payment details
  paymentMethod   String?                             // DIGITAL, COD
  paymentRef      String?                             // MoMo/ZaloPay transaction ID
  collectedBy     String?                             // Rep or Driver user ID (for cash collection)
  
  // Metadata
  description     String?                             // Human-readable description
  metadata        String?                             // JSON: additional data
  
  // Relations
  shop            Shop      @relation(fields: [shopId], references: [id])
  order           Order?     @relation(fields: [orderId], references: [id])

  createdAt       DateTime @default(now())

  @@index([shopId])
  @@index([orderId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================
// GROUP BUY ENGINE (Mua Chung — Pinduoduo model)
// ============================================================

model GroupDeal {
  id              String   @id @default(cuid())
  title           String                             // Vietnamese: "Gạo ST25 Group Buy Ward 5"
  titleEn         String?
  description     String?
  productId       String                             // The product being grouped
  
  // Threshold & Pricing
  targetQty       Int                                 // Minimum quantity to unlock discount
  currentQty      Int      @default(0)               // Current committed quantity
  originalPrice   Int                                 // Normal price per unit
  discountPrice   Int                                 // Group buy price per unit
  maxParticipants Int?                                // Cap on number of shops (null = unlimited)
  
  // Timing
  startsAt        DateTime
  expiresAt       DateTime                            // Auto-cancel if not met
  
  // Zone
  wardId          String?                             // Scoped to ward for local group buying
  
  // Status
  status          String   @default("ACTIVE")         // ACTIVE, COMPLETED, CANCELLED, EXPIRED
  
  // When deal is completed, create a bulk order
  bulkOrderId     String?                            // The consolidated order sent to distributor

  // Relations
  product         Product   @relation(fields: [productId], references: [id])
  ward            Ward?     @relation(fields: [wardId], references: [id])
  participants    GroupDealParticipant[]
  orders          Order[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productId])
  @@index([wardId])
  @@index([status])
  @@index([expiresAt])
}

model GroupDealParticipant {
  id              String   @id @default(cuid())
  groupDealId     String
  shopId          String
  committedQty    Int                                 // How many units this shop committed
  isActive        Boolean  @default(true)             // Can withdraw before deal completes
  
  // Relations
  groupDeal       GroupDeal @relation(fields: [groupDealId], references: [id])
  shop            Shop      @relation(fields: [shopId], references: [id])

  createdAt       DateTime @default(now())

  @@unique([groupDealId, shopId])                    // One participation per deal per shop
  @@index([shopId])
}

// ============================================================
// LOGISTICS: SHIPMENTS & DELIVERY
// ============================================================

model Shipment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  type            String   @default("INTERNAL")       // INTERNAL, THIRD_PARTY (Ahamove/Grab)
  
  // Status
  status          String   @default("PENDING")        // PENDING, PICKED_UP, IN_TRANSIT, DELIVERED, FAILED
  
  // Driver
  assignedDriverId String?
  
  // Route
  pickupAddress   String?                            // Distributor/warehouse location
  pickupLat       Float?
  pickupLng       Float?
  dropoffAddress  String                             // Shop address
  dropoffLat      Float?
  dropoffLng      Float?
  
  // Proof of Delivery
  deliveredAt     DateTime?
  podPhotoUrl     String?                             // Proof of delivery photo
  podSignatureUrl String?                             // Digital signature
  podOtp          String?                             // OTP confirmed by shop owner
  
  // 3rd Party
  thirdPartyTrackingId String?                       // Ahamove/Grab order ID
  thirdPartyStatus    String?

  // Relations
  order           Order     @relation(fields: [orderId], references: [id])
  assignedDriver  User?     @relation("DriverAssignments", fields: [assignedDriverId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([assignedDriverId])
  @@index([status])
}

// ============================================================
// SFA: PROMOTIONS & MERCHANDISING (Trade Marketing)
// ============================================================

model Promotion {
  id              String   @id @default(cuid())
  manufacturerId  String
  title           String
  titleEn         String?
  description     String?
  
  // Promotion type
  promoType       String                              // BUY_X_GET_Y, PERCENT_OFF, FIXED_DISCOUNT
  buyQty          Int?                                // For BUY_X_GET_Y: buy X
  getQty          Int?                                // For BUY_X_GET_Y: get Y free
  discountPercent Float?                              // For PERCENT_OFF
  discountAmount  Int?                                // For FIXED_DISCOUNT
  
  // Validity
  startsAt        DateTime
  expiresAt       DateTime
  
  // Budget & Tracking
  totalBudget     Int?                                // Manufacturer's budget (VND)
  usedBudget      Int      @default(0)
  totalRedemptions Int     @default(0)
  
  isActive        Boolean  @default(true)

  // Relations
  manufacturer    Manufacturer @relation(fields: [manufacturerId], references: [id])
  items           PromotionItem[]
  orderItems      OrderItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([manufacturerId])
  @@index([isActive])
  @@index([expiresAt])
}

model PromotionItem {
  id              String   @id @default(cuid())
  promotionId     String
  productId       String                             // Product this promo applies to

  // Relations
  promotion       Promotion @relation(fields: [promotionId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])

  createdAt       DateTime @default(now())

  @@unique([promotionId, productId])
  @@index([productId])
}

model MerchandisingAudit {
  id              String   @id @default(cuid())
  shopId          String
  productId       String?
  promotionId     String?
  photoUrl        String                             // Shelf photo from shop owner
  
  // Audit result
  status          String   @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, REJECTED
  reviewerId      String?                             // Admin who reviewed
  reviewNotes     String?
  reviewedAt      DateTime?

  // Relations
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shopId])
  @@index([status])
}

// ============================================================
// BROKER NETWORK
// ============================================================

model Broker {
  id              String   @id @default(cuid())
  userId          String   @unique
  tier            String   @default("WARD_LEVEL")    // WARD_LEVEL, CATEGORY_SPECIALIST, FACTORY_GATE
  wardId          String?                             // Territory assignment
  commissionRate  Float    @default(0.03)            // 3% standard commission
  
  // Stats
  totalShopsReferred Int   @default(0)
  totalCommissionEarned Int @default(0)
  totalGmvGenerated    Int @default(0)

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ward            Ward?    @relation(fields: [wardId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tier])
  @@index([wardId])
}

// ============================================================
// PAYMENT: Digital Payment Gateway Tracking (Sprint 4F)
// ZaloPay, MoMo, and Mock gateway integration
// ============================================================

model Payment {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  gateway       String                                     // ZALOPAY, MOMO, MOCK
  gatewayTxId   String?  @unique                            // Gateway transaction ID
  amount        Int                                        // Amount in VND
  status        String   @default("PENDING")                // PENDING, SUCCESS, FAILED, EXPIRED
  paymentUrl    String?                                     // URL for user to pay
  qrCodeUrl     String?
  rawRequest    String?                                     // JSON: gateway request for debugging
  rawCallback   String?                                     // JSON: gateway callback for debugging
  paidAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
  @@index([gatewayTxId])
  @@index([status])
}

// ============================================================
// DISTRIBUTOR INVENTORY: Per-distributor stock tracking
// ============================================================

model DistributorInventory {
  id              String     @id @default(cuid())
  distributorId   String
  productId       String
  
  quantity        Int        @default(0)                  // Current stock level
  reservedQty     Int        @default(0)                  // Reserved for pending orders
  minStockLevel   Int        @default(10)                 // Low-stock alert threshold
  costPrice       Int?                                   // Cost price per unit (VND)

  // Relations
  distributor     Distributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([distributorId, productId])               // One stock record per product per distributor
  @@index([distributorId])
  @@index([productId])
}

// Inventory Movement Audit Trail
model InventoryMovement {
  id              String   @id @default(cuid())
  distributorId   String
  productId       String
  type            String                                     // RECEIPT, ADJUSTMENT, ORDER_FULFILLMENT, RETURN, DAMAGE
  quantity        Int                                        // Positive = in, Negative = out
  previousQty     Int                                        // Stock before movement
  newQty          Int                                        // Stock after movement
  reason          String?                                    // Human-readable reason
  orderId         String?                                    // If from order fulfillment
  performedBy     String                                     // User ID who made the change

  // Relations
  distributor     Distributor @relation(fields: [distributorId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])

  createdAt       DateTime @default(now())

  @@index([distributorId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================
// SETTLEMENTS: Platform fee collection & distributor/driver payouts
// Model A + C: Aladin collects full amount, splits it out
// ============================================================

model PlatformFeeConfig {
  id              String   @id @default(cuid())
  name            String                                     // e.g., "Standard 3%"
  feeType         String   @default("PERCENTAGE")          // PERCENTAGE, FLAT, TIERED
  rate            Float    @default(0.03)                   // 3% platform fee
  flatFee         Int?                                     // For FLAT type (VND per order)
  minFee          Int      @default(0)                      // Minimum fee (VND)
  maxFee          Int?                                     // Maximum fee cap (VND, null = unlimited)
  isActive        Boolean  @default(true)
  appliesTo       String   @default("ALL")                  // ALL, DISTRIBUTOR, DRIVER
  effectiveFrom   DateTime @default(now())
  effectiveTo     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Settlement {
  id              String   @id @default(cuid())
  settlementNumber String  @unique                         // e.g., "STL-20260622-W01"
  distributorId   String
  
  // Period
  periodStart     DateTime                                   // Start of settlement period
  periodEnd       DateTime                                   // End of settlement period
  
  // Financial Summary
  totalOrders     Int      @default(0)                     // Number of orders in this settlement
  totalOrderValue Int      @default(0)                     // Sum of all order amounts (VND)
  totalPlatformFee Int     @default(0)                     // Aladin's cut (VND)
  totalDeliveryFee Int     @default(0)                     // Total delivery fees (VND)
  distributorPayout Int    @default(0)                     // Net payout to distributor (VND)
  driverPayouts   Int      @default(0)                     // Total paid to drivers (VND)
  
  // Status
  status          String   @default("PENDING")             // PENDING, PROCESSING, PAID, FAILED
  paidAt          DateTime?
  paymentRef      String?                                   // Bank transfer reference
  notes           String?

  // Relations
  distributor     Distributor @relation(fields: [distributorId], references: [id])
  lineItems       SettlementLineItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([distributorId])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
}

model SettlementLineItem {
  id              String   @id @default(cuid())
  settlementId    String
  orderId         String
  orderNumber     String
  
  // Financial breakdown per order
  orderAmount     Int                                       // Full order total (VND)
  platformFee     Int                                       // Platform fee on this order (VND)
  deliveryFee     Int                                       // Delivery fee on this order (VND)
  distributorAmount Int                                     // Net to distributor (VND)
  driverAmount    Int                                       // Driver payout (VND)
  driverId        String?                                   // If driver was assigned

  // Relations
  settlement      Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([settlementId])
  @@index([orderId])
}

// ============================================================
// SETTINGS & AUDIT: Platform Config + Audit Trail (Sprint 5H)
// ============================================================

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?                                    // Admin who performed the action (null for system)
  action        String                                     // e.g., USER_ROLE_CHANGED, ORDER_CANCELLED, PASSWORD_RESET
  entity        String                                     // e.g., User, Order, Shop, PlatformSetting
  entityId      String?                                    // ID of the affected entity
  details       String?                                    // JSON: before/after snapshot, change details
  ipAddress     String?
  userAgent     String?

  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}

model PlatformSetting {
  id            String   @id @default(cuid())
  key           String   @unique                           // e.g., credit.defaultLimit, platform.name
  value         String                                     // JSON or plain string value
  description   String?                                    // Human-readable description
  category      String   @default("general")               // general, credit, notification, security

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// NOTIFICATIONS: In-app notification system
// Phase 4 — Real-Time & Scale
// ============================================================

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String                                       // ORDER_STATUS, SHIPMENT, CREDIT, SETTLEMENT, INVENTORY, SYSTEM, PROMOTION
  title       String
  message     String
  data        Json?                                        // optional structured data (orderId, shipmentId, etc.)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  readAt      DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ============================================================
// CHAT: In-app messaging between users and ALADIN support
// Sprint M7 — Zalo Chat integration layer
// ============================================================

model ChatMessage {
  id              String   @id @default(cuid())
  userId          String                                       // Sender (shop owner / broker)
  conversationId  String                                       // Thread ID (user-specific, one conversation per user)
  
  direction       String   @default("OUTGOING")                // OUTGOING (user → support), INCOMING (support → user)
  messageType     String   @default("TEXT")                    // TEXT, IMAGE, QUICK_REPLY, SYSTEM
  content         String                                        // Message text content
  imageUrl        String?                                       // Image attachment URL
  metadata        String?                                       // JSON: quick reply options, etc.
  
  isRead          Boolean  @default(false)                     // Read by recipient
  
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([conversationId])
  @@index([createdAt])
}

// ============================================================
// POS: Point of Sale for distributor walk-in sales
// Phase 2 — POS Module
// ============================================================

model PosShift {
  id                String   @id @default(cuid())
  distributorId     String
  
  // Timing
  openedAt          DateTime @default(now())
  closedAt          DateTime?
  
  // Financial
  openingBalance    Int      @default(0)                        // Cash in drawer at shift start (VND)
  closingBalance    Int?                                       // Cash in drawer at shift end (VND)
  expectedCash      Int      @default(0)                        // Expected cash based on sales
  cashDifference    Int?                                       // closingBalance - expectedCash
  
  // Totals by payment method
  cashTotal         Int      @default(0)                        // Total CASH sales (VND)
  bankTransferTotal Int      @default(0)                        // Total BANK_TRANSFER sales (VND)
  debtTotal         Int      @default(0)                        // Total DEBT sales (VND)
  salesCount        Int      @default(0)                        // Number of transactions
  
  // Status
  status            String   @default("OPEN")                   // OPEN, CLOSED
  
  // Operator
  openedBy          String                                      // User who opened the shift
  closedBy          String?                                     // User who closed the shift
  
  // Notes
  closingNotes      String?
  
  // Relations
  distributor       Distributor @relation("DistributorPosShifts", fields: [distributorId], references: [id])
  saleItems         PosSaleItem[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([distributorId])
  @@index([status])
  @@index([openedAt])
}

model PosSaleItem {
  id                String   @id @default(cuid())
  posShiftId        String
  distributorId     String
  
  // Product info (snapshot)
  productId         String
  productName       String
  productSku        String?
  unitPrice         Int                                         // Selling price per unit (VND)
  quantity          Int
  totalPrice        Int                                         // unitPrice * quantity
  
  // Payment
  paymentMethod     String                                      // CASH, BANK_TRANSFER, DEBT
  saleTotal         Int                                         // Total of entire sale (if multiple items)
  saleSequence      Int                                         // Sequence number within the sale
  
  // Customer (optional)
  customerName      String?
  customerPhone     String?
  
  // Order link (if sale was linked to a shop order)
  orderId           String?
  
  // Inventory movement
  movementId        String?                                     // Link to InventoryMovement record
  
  createdAt         DateTime @default(now())
  
  // Relations
  posShift          PosShift @relation(fields: [posShiftId], references: [id], onDelete: Cascade)
  distributor       Distributor @relation("DistributorPosSales", fields: [distributorId], references: [id])
  
  @@index([posShiftId])
  @@index([distributorId])
  @@index([createdAt])
  @@index([paymentMethod])
}

// ============================================================
// DISTRIBUTOR CRM: Customer management & Loyalty Points
// Inspired by Odoo CRM + MISA customer tracking
// Vietnamese distributors sell to 50-200 recurring shop owners.
// This module tracks their own customer base (separate from platform shops).
// ============================================================

model DistributorCustomer {
  id              String   @id @default(cuid())
  distributorId   String

  // Identity
  code            String                               // Customer code: "KH-001"
  name            String                               // Shop/customer name
  phone           String                               // Contact phone
  address         String?
  district        String?
  province        String   @default("Binh Duong")

  // Business info
  shopType        String?                              // TAPHOA, CONVENIENCE, RESTAURANT, FACTORY
  taxId           String?                              // MST (tax ID for invoicing)
  note            String?

  // Loyalty points (append-only via LoyaltyTransaction)
  loyaltyPoints   Int      @default(0)                 // Current point balance (denormalized)
  loyaltyTier     String   @default("BRONZE")          // BRONZE, SILVER, GOLD, PLATINUM
  totalSpend      Int      @default(0)                 // Cumulative spend for tier calc (VND)
  totalOrders     Int      @default(0)                 // Total order count

  // Credit terms (distributor-specific, separate from platform credit)
  creditLimit     Int      @default(0)                 // 0 = COD only (VND)
  creditBalance   Int      @default(0)                 // Outstanding debt (VND)
  creditStatus    String   @default("ACTIVE")          // ACTIVE, LOCKED, OVERDUE
  paymentTermsDays Int     @default(0)                 // 0 = COD, 7/14/30 days

  // Status
  isActive        Boolean  @default(true)

  // Relations
  distributor     Distributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  loyaltyTransactions LoyaltyTransaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([distributorId, code])
  @@unique([distributorId, phone])
  @@index([distributorId])
  @@index([loyaltyTier])
  @@index([creditStatus])
  @@index([name])
}

model LoyaltyTransaction {
  id              String   @id @default(cuid())
  customerId      String
  distributorId   String

  type            String                               // EARN, REDEEM, ADJUST, EXPIRE
  points          Int                                  // Positive = earn, Negative = redeem
  balance         Int                                  // Points balance after this tx
  description     String?

  // Source
  orderId         String?                              // If earned from an order
  reference       String?                              // External reference

  createdAt       DateTime @default(now())

  // Relations
  customer        DistributorCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  distributor     Distributor @relation(fields: [distributorId], references: [id])

  @@index([customerId])
  @@index([distributorId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================
// PRICE TIERS: Multi-tier pricing (Odoo Pricelists concept)
// Different prices for different customer segments or volume levels.
// Helps distributors improve GVM by offering volume incentives
// while maintaining margins on small orders.
// ============================================================

model PriceTier {
  id              String   @id @default(cuid())
  distributorId   String

  name            String                               // "Gia si", "Gia VIP", "Gia dai ly"
  nameEn          String?
  tierType        String   @default("CUSTOM")           // LOYALTY_BASED, VOLUME_BASED, CUSTOM
  discountPercent Float   @default(0)                   // % discount from base price
  minOrderValue   Int?                                 // Minimum order value to qualify (VND)
  loyaltyTier     String?                              // Which loyalty tier this applies to

  isActive        Boolean  @default(true)

  // Relations
  distributor     Distributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  items           PriceTierItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([distributorId])
}

model PriceTierItem {
  id              String   @id @default(cuid())
  priceTierId     String
  productId       String

  price           Int                                  // Price at this tier (VND per unit)

  // Relations
  priceTier       PriceTier @relation(fields: [priceTierId], references: [id], onDelete: Cascade)
  product         Product   @relation("PriceTierProduct", fields: [productId], references: [id])

  createdAt       DateTime @default(now())

  @@unique([priceTierId, productId])
  @@index([productId])
}

// ============================================================
// PUSH NOTIFICATIONS: Web push subscription management
// Wave 4 — Real-time push notifications
// ============================================================

model PushSubscription {
  id              String   @id @default(cuid())
  userId          String
  endpoint        String                                       // Push service endpoint URL
  p256dhKey       String                                       // ECDH public key
  authKey         String                                       // Auth secret
  userAgent       String   @default("")                        // Browser/device info
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

// ============================================================
// NOTIFICATION PREFERENCES: Per-user notification channel settings
// Wave 4 — Granular notification control
// ============================================================

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique

  // Channel toggles
  inAppEnabled    Boolean  @default(true)                      // In-app notifications
  pushEnabled     Boolean  @default(true)                      // Browser push notifications
  zaloEnabled     Boolean  @default(true)                      // Zalo OA messages

  // Per-type toggles (in-app)
  orderUpdates    Boolean  @default(true)                      // ORDER_STATUS
  shipmentUpdates Boolean  @default(true)                      // SHIPMENT
  creditAlerts    Boolean  @default(true)                      // CREDIT, debt reminders
  promotions      Boolean  @default(true)                      // PROMOTION
  systemAlerts    Boolean  @default(true)                      // SYSTEM, INVENTORY

  // Quiet hours (Vietnam timezone, stored as HH:MM strings)
  quietHoursEnabled Boolean @default(false)
  quietHoursStart   String @default("22:00")                   // 10PM
  quietHoursEnd     String @default("07:00")                   // 7AM

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
